HANDLER_DRAG_PARAM_location"><block type="argument_reporter_custom" id="yhs)k3Wr@xJ@C`F0HPGI" deletable="false"><mutation typename="tiles.Location"></mutation><field name="VALUE">location</field></block></value><statement name="HANDLER"><block type="controls_if" id="F62wou$)YD71}xaqVAz;"><value name="IF0"><shadow type="logic_boolean" id="b!uA~U,-`|UDb{d|SFE}"><field name="BOOL">TRUE</field></shadow><block type="keyispressed" id="XJ3kTn_,ZHr?8y@Uz`q|"><field name="button">controller.A</field></block></value><statement name="DO0"><block type="controls_if" id="psG*,bX0r6zJ@l`hXcTJ"><mutation else="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="cWBI%CMa`?N;M5P]m=(a"><field name="BOOL">TRUE</field></shadow><block type="variables_get" id="*l(7H8b(wg)V]2E6~4s{"><field name="VAR" id="l0]#DcXvyn.:`sn[o)W_">mySprite6</field></block></value><statement name="DO0"><block type="game_show_long_text" id="j)vRK{DahmCv?(*3P:Ti"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="vk-;%zw[+49|D?2%6+XZ"><field name="TEXT">*Gasp* Why are you with the manifestation of chaos and despair?</field></shadow></value><next><block type="game_show_long_text" id="Z=q?i2k7fhy(CiA?GR-6"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="bf5PR:5xrv4P~.R,];XO"><field name="TEXT">I didn't expect the hero of legend to be accompanied by such a malevolent force.</field></shadow></value><next><block type="game_show_long_text" id="oC;#G@ZmdtCVo/88oN!C"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="r@siWkb!(U9bUsAgo0II"><field name="TEXT">I am the only resident of this crumbling ruin. I can't leave because of the corruption. Only the hero, you, and any manifestation of chaos can traverse that area.</field></shadow></value><next><block type="game_show_long_text" id="ZGSuJ?Iuu]ozt]!X@cUf"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="S1:T#JcFh*bs6.OUoGjg"><field name="TEXT">Shade: Really, I'm not evil! I'm just weird is all! Trust me.</field></shadow></value><next><block type="game_show_long_text" id="hR0Is;M_-=AwQP(PCWjB"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="$PO69*@]Y.wZ`~Dz`B}*"><field name="TEXT">Shade: I don't even have any reason to live honestly if all get is this reaction to me! I'm glad though that you didn't fight me.</field></shadow></value></block></next></block></next></block></next></block></next></block></statement><statement name="ELSE"><block type="game_show_long_text" id="E^=Jaf.:e5=pqq%5Sc!o"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="gd3m4$_Va5[maE4UJD?x"><field name="TEXT">Hello.</field></shadow></value></block></statement></block></statement></block></statement></block><block type="spriteshittile" id="Y1+W[j!r2pd1gCy)Cke}" x="5308" y="4879"><value name="HANDLER_DRAG_PARAM_sprite"><block type="argument_reporter_custom" id="S1IlOhQqvCG^fSq^TKHe" deletable="false"><mutation typename="Sprite"></mutation><field name="VALUE">sprite</field></block></value><value name="kind"><shadow type="spritekind" id="o#Yo0cRULKF7s1nr~}5,"><field name="MEMBER">Player</field></shadow></value><value name="tile"><shadow type="tileset_tile_picker" id="|2JIM*(8:@b-42Hpn1JX"><field name="tile">assets.tile`myTile103`</field></shadow></value><value name="HANDLER_DRAG_PARAM_location"><block type="argument_reporter_custom" id="f^!/g6~M9S^kD.MGYp|;" deletable="false"><mutation typename="tiles.Location"></mutation><field name="VALUE">location</field></block></value><statement name="HANDLER"><block type="variables_set" id="nRY4ko`L7|)ls^@Jm?XP"><field name="VAR" id="=jH}JTiZH1}7L,9P$.d_">Spawning</field><value name="VALUE"><shadow type="math_number" id="VYz:3ZBG^k9iQA|1X}UR"><field name="NUM">0</field></shadow><block type="logic_boolean" id="tfUVA8b2?T{*uw9ce|;g"><field name="BOOL">FALSE</field></block></val