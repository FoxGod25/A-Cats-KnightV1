wz.cn5q"><mutation else="1"></mutation><value name="IF0"><shadow type="logic_boolean" id=":!SM$fG8vG_Hg3c(oH8~"><field name="BOOL">TRUE</field></shadow><block type="gameask" id="s(..m;L,6-W#bPMdA=B8"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id=";n0vs#Yi3ZUxyL(;E,D-"><field name="TEXT">"Are you enjoying this game?"</field></shadow></value><value name="subtitle"><shadow type="text" id="X1d%.DzbxG~_+Ue/)%6O"><field name="TEXT"></field></shadow></value></block></value><statement name="DO0"><block type="game_show_long_text" id="W!:K`CrrgE`DWS$GvG]F"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="IGqhGjsr!Yo6vnJrN?8{"><field name="TEXT">"Good. Anyways, you need wood right? Here."</field></shadow></value><next><block type="variables_set" id="3lXP!KMFuIP?;^IB0Qwe"><field name="VAR" id="`][V`QbAND}wF8eb::^G">Wood</field><value name="VALUE"><shadow type="math_number" id=".b_xkSy-y-?Q/fP*-@9M"><field name="NUM">1</field></shadow><block type="logic_boolean" id="=A!3lW^N/NJg[fYgApc?"><field name="BOOL">TRUE</field></block></value></block></next></block></statement><statement name="ELSE"><block type="game_show_long_text" id="Xp?*|F~PL+]a]T?}e(XL"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="T=Bf]K+YwVNBLAE!O]ra"><field name="TEXT">"That's a bummer. Here, take this wood."</field></shadow></value><next><block type="variables_set" id="JXbt+dpE^qx+RrtHdzXf"><field name="VAR" id="`][V`QbAND}wF8eb::^G">Wood</field><value name="VALUE"><shadow type="math_number" id="Th*erS^=)g+T8i;bk=BP"><field name="NUM">1</field></shadow><block type="logic_boolean" id="jO`/Y,+{oAoodzgY=MxQ"><field name="BOOL">TRUE</field></block></value><next><block type="controls_if" id="6oB7_m4]t}9SMB[O:-_|"><value name="IF0"><shadow type="logic_boolean" id="_f-c{[KnX00Ba1%MFD9["><field name="BOOL">TRUE</field></shadow><block type="keyispressed" id="_aTgle6#f40iQC8zeV$w"><field name="button">controller.B</field></block></value><statement name="DO0"><block type="game_show_long_text" id="MW`BmhKe2JV2|@EQC0x7"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=".iIsj|U0WM*z+lG;N1~("><field name="TEXT">"I don't want to code an inventory, so you'll have to handle my sub-standard programming.(PS:Impact is taking up 2 GB's on my laptop while coding. HELP!)"</field></shadow></value></block></statement></block></next></block></next></block></statement></block></next></block></statement><statement name="ELSE"><block type="controls_if" id="Qy7z%f@K{iirEQtd1N+~"><mutation elseif="2" else="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="sLm[G#4L0gs_n/vTo2dY"><field name="BOOL">TRUE</field></shadow><block type="percentchance" id="L;/,hOn]cA;XfT!L1b~}"><value name="percentage"><shadow type="math_number_minmax" id="f=ZC2Ffd6AGNwcAGY5X1"><mutation min="0" label="Percentage" precision="0"></mutation><field name="SLIDER">33</field></shadow></value></block></value><statement name="DO0"><block type="game_show_long_text" id="{?GpeX2(c3#;[nkE{Tn%"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="gCJ;yB/);9oPNL|k00[."><field name="TEXT">"Did you know that I'm partially related to Shade in this universe?</field></shadow></value><next><block type="game_show_long_text" id="h7SV{~uLBTRWitC{r:or"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="=q*_Gp,%mmGRH_eH`K%D"><field name="TEXT"> Yeah, I'm part whatever Shade is, and part fox."</field></shadow></value></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="6e`7SO|g9y@%=}^gq1@]"><field name="BOOL">FALSE</field></shadow><block type="percentchance" id="fkK-)TMSXn6ieaY;=Vd-"><value name="percentage"><shadow type="math_number_minmax" id="^|qK#~B-[4!2N(hI5@Yk"><mutation min="0" label="Percentage" precision="0"></mutat